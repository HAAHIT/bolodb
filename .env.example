# Generate a secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Required: PostgreSQL connection string for application state
# Example: postgresql+asyncpg://user:pass@localhost:5432/bolodb
DATABASE_URL=
# Set to "true" when behind HTTPS termination (nginx with SSL)
COOKIE_SECURE=false
# Set to "true" when running inside Docker
RUNNING_IN_DOCKER=false
# PostHog analytics (https://posthog.com — project settings → API Key)
PUBLIC_POSTHOG_PROJECT_TOKEN=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Supabase (for Google OAuth) — find these in your Supabase dashboard under Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
