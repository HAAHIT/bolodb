# Generate a secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Set to "true" when behind HTTPS termination (nginx with SSL)
COOKIE_SECURE=false
# PostHog analytics (optional)
PUBLIC_POSTHOG_PROJECT_TOKEN=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
PUBLIC_DEPLOY_MODE=true
# Supabase / PostgreSQL
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
# MyEmailVerifier API key (optional, for email verification at signup)
# https://client.myemailverifier.com/
MYEMAILVERIFIER_API_KEY=
# Resend API key (optional, for sending verification and password-reset emails)
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@bolodb.dev
# Frontend URL for building reset/verification links
FRONTEND_URL=
