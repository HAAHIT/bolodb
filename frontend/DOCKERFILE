# ──────────────────────────────────────────────
#  BoloDB  ·  Frontend (Svelte)
#  Multi-stage: Node builds → output to volume
# ──────────────────────────────────────────────
#  Build context: ./frontend
# ──────────────────────────────────────────────
FROM node:26-alpine AS builder

WORKDIR /app

# ── 1. Install dependencies (cached layer) ──
COPY package.json package-lock.json* ./
RUN npm ci

# ── 2. Copy source & build ──
COPY . .
RUN npm run build

# ── 3. Minimal output stage ──
#  The built assets are copied to /app/build (SvelteKit static adapter default).
#  docker-compose mounts this as a shared volume for Nginx.
FROM alpine:3.20

COPY --from=builder /app/build /app/dist

# Keep the container alive so the volume stays mounted
CMD ["tail", "-f", "/dev/null"]
