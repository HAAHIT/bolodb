# ──────────────────────────────────────────────
#  BoloDB  ·  Frontend (Svelte) - Development
# ──────────────────────────────────────────────

FROM node:26-alpine

WORKDIR /app

# Install dependencies (cached layer)
COPY package.json package-lock.json* ./
RUN npm ci

# Copy source files
COPY . .

EXPOSE 5173

# Run the dev server on all network interfaces (host 0.0.0.0)
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
