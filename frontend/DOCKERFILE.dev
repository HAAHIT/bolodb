# ──────────────────────────────────────────────
#  BoloDB  ·  Frontend (Svelte) - Development
# ──────────────────────────────────────────────

FROM node:26-alpine

WORKDIR /app

# Install dependencies (cached layer)
COPY package.json package-lock.json* ./
RUN npm ci

# Copy source files
COPY . .

EXPOSE 5173

# docker-compose.yml mounts an anonymous volume over /app/node_modules so the
# bind-mounted source doesn't shadow it. That volume persists across
# `docker compose up --build` (only the image's node_modules gets rebuilt),
# so a container recreated from an old volume can silently run with
# dependencies missing whenever package.json gains a new one — surfacing as
# ERR_MODULE_NOT_FOUND for a package that installs fine everywhere else.
# Reconcile against the lockfile on every start so the volume can't go stale.
CMD ["sh", "-c", "npm install && npm run dev -- --host 0.0.0.0"]
