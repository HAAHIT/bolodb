# ──────────────────────────────────────────────
#  BoloDB  ·  Nginx (production)
#  Builds the SvelteKit static frontend, then
#  serves it and reverse-proxies /api → backend.
# ──────────────────────────────────────────────
#  Build context: repository root (.)
# ──────────────────────────────────────────────
FROM node:26-alpine AS frontend-builder

WORKDIR /app

COPY frontend/package.json frontend/package-lock.json* ./
RUN npm ci

COPY frontend/ .

# Workaround for Coolify multi-stage build context missing files in second stage
COPY nginx/nginx.conf ./nginx.conf


# SvelteKit static adapter bakes $env/dynamic/public at build time.
ARG PUBLIC_POSTHOG_PROJECT_TOKEN
ARG PUBLIC_POSTHOG_HOST
ENV PUBLIC_POSTHOG_PROJECT_TOKEN=$PUBLIC_POSTHOG_PROJECT_TOKEN \
    PUBLIC_POSTHOG_HOST=$PUBLIC_POSTHOG_HOST

RUN npm run build

# ── Runtime: nginx serves static + proxies API ──
FROM nginx:1.27-alpine

RUN rm -rf /usr/share/nginx/html/* /etc/nginx/conf.d/default.conf

COPY --from=frontend-builder /app/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=frontend-builder /app/build /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
    CMD wget -q -O /dev/null http://127.0.0.1:80/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
