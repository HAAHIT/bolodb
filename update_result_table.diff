/* ---------- ResultTable ---------- */
const ResultTable = React.memo(function ResultTable({ columns, rows, max=8 }) {
  const [copied, setCopied] = React.useState(false);

  function copyCSV(){
    // Guard against CSV/formula injection: cells starting with =,+,-,@ are
    // prefixed with ' so spreadsheet tools treat them as text, not formulas.
    const cell = (v)=>{
      let s = String(v??'');
      if (/^[=+\-@]/.test(s)) s = "'" + s;
      return (s.includes(',')||s.includes('"')||s.includes('\n')) ? `"${s.replace(/"/g,'""')}"` : s;
    };
    const header = columns.map(cell).join(",");
    const body = rows.map(r=>r.map(cell).join(",")).join("\n");
    navigator.clipboard.writeText(header+"\n"+body).then(() => {
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
    }).catch(()=>{});
  }

  if (!rows || rows.length===0) {
    return (
      <div style={{padding:"22px 18px",textAlign:"center",color:"var(--muted)",
